PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/colors.sh"

FONT="JetBrainsMono Nerd Font"
GAP=6

##### Bar #####
sketchybar --bar position=top \
  height=38 \
  margin=10 \
  y_offset=4 \
  corner_radius=6 \
  blur_radius=5 \
  padding_left=10 \
  padding_right=10 \
  color=$BG \
  border_width=1 border_color=0x28222222 \
  shadow.color=0x28000000 shadow.angle=0

##### Defaults #####
default=(
  padding_left=2
  padding_right=2
  icon.font="$FONT:Bold:16.0"
  label.font="$FONT:Bold:14.0"
  icon.color=$WHITE
  label.color=$WHITE
  icon.padding_left=6
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=6
  background.color=$WORKSPACE_BG
  background.corner_radius=4
  background.height=28
  background.border_width=2
  background.border_color=$BORDER_COLOR
  updates=on
)
sketchybar --default "${default[@]}"

##### Left — OS icon #####
sketchybar --add item os left \
  --set os \
  icon= icon.color=0xfff5c2e7 \
  icon.font.size=21 icon.y_offset=2 \
  icon.padding_left=0 icon.padding_right=0 \
  label.padding_left=0 label.padding_right=6 \
  background.drawing=off

##### Left — Workspaces #####
WORKSPACE_ICONS=(
  ""  # 1: terminal
  ""  # 2: code
  ""  # 3: browser
  ""   # 4: other
  ""   # 5: social/media
  ""   # 6: files
  "󰻞"  # 7: chat/communication
  ""  # 8: browser
  "󰝚"  # 9: music
)

for sid in {1..9}; do
  display_id="1"
  if [ "$sid" -ge 6 ] && [ "$sid" -le 10 ]; then
    display_id="2"
  fi

  sketchybar --add item space.$sid left \
    --set space.$sid \
    display="$display_id" \
    icon="${WORKSPACE_ICONS[$((sid-1))]}" \
    icon.padding_left=12 icon.padding_right=12 \
    label.drawing=off \
    background.border_color=$WORKSPACE_BORDER_COLOR \
    click_script="aerospace workspace $sid"
done

##### Left — Workspace monitor (hidden, polls aerospace) #####
sketchybar --add item aerospace_monitor left \
  --set aerospace_monitor \
  update_freq=1 \
  drawing=off \
  script="$PLUGIN_DIR/aerospace_update_all.sh" \
  --subscribe aerospace_monitor force_update

##### Right — Clock / Volume / Battery #####
sketchybar --add item clock right \
  --set clock \
  update_freq=10 \
  script="$PLUGIN_DIR/clock.sh"

sketchybar --add item volume right \
  --set volume \
  script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

sketchybar --add item battery right \
  --set battery \
  update_freq=120 \
  script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

##### Right — CPU / RAM #####
sketchybar --add item cpu right \
  --set cpu \
  update_freq=5 \
  script="$PLUGIN_DIR/cpu.sh"

sketchybar --add item ram right \
  --set ram \
  update_freq=5 \
  script="$PLUGIN_DIR/ram.sh"

##### Right — Spotify #####
SPOTIFY_ICON_SIZE=19
SPOTIFY_CTRL_PAD=6

# Common properties for spotify control buttons
spotify_ctrl=(
  icon.padding_left=$SPOTIFY_CTRL_PAD
  icon.padding_right=$SPOTIFY_CTRL_PAD
  label.drawing=off
  padding_left=0
  padding_right=0
  background.drawing=off
  script="$PLUGIN_DIR/spotify.sh"
)

sketchybar --add event spotify_change com.spotify.client.PlaybackStateChanged

sketchybar --add item spotify right \
  --set spotify \
  icon.padding_right=$GAP \
  label.padding_left=$GAP \
  update_freq=15 \
  script="$PLUGIN_DIR/spotify.sh" \
  --subscribe spotify spotify_change mouse.clicked

sketchybar --add item spotify.next right \
  --set spotify.next icon=󰒭 icon.font.size=$SPOTIFY_ICON_SIZE \
  "${spotify_ctrl[@]}" \
  --subscribe spotify.next mouse.clicked

sketchybar --add item spotify.playpause right \
  --set spotify.playpause icon= icon.font.size=12 icon.y_offset=1 \
  "${spotify_ctrl[@]}" \
  --subscribe spotify.playpause mouse.clicked

sketchybar --add item spotify.back right \
  --set spotify.back icon=󰒮 icon.font.size=$SPOTIFY_ICON_SIZE \
  "${spotify_ctrl[@]}" \
  --subscribe spotify.back mouse.clicked

sketchybar --add bracket spotify_controls \
  spotify.next spotify.playpause spotify.back \
  --set spotify_controls \
  background.drawing=on

##### Init #####
sketchybar --update
